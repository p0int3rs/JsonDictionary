<Window x:Class="JsonDictionary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Json Dictionary"
        Height="850" Width="1000"
        Background="#1E1E26">

    <Window.Resources>

        <!-- Modern Primary Button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="Background"
                                Value="#3E3E42"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                Property="Opacity"
                                Value="0.85"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton"
           TargetType="Button"
           BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Başlık -->
            <RowDefinition Height="Auto"/>
            <!-- Dosya seç -->
            <RowDefinition Height="Auto"/>
            <!-- Input alanı -->
            <RowDefinition Height="Auto"/>
            <!-- Butonlar -->
            <RowDefinition Height="*"/>
            <!-- Liste -->
        </Grid.RowDefinitions>

        <!-- BAŞLIK -->
        <TextBlock Text="Advanced JSON Dictionary"
                   FontSize="28"
                   Foreground="#00D1FF"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- DOSYA SEÇME -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="DosyaYolu"
                     IsReadOnly="True"
                     Background="#252530"
                     Foreground="White"
                     BorderBrush="#00D1FF"
                     BorderThickness="1"
                     Padding="8"
                     Text="Json dosyası seçin..."/>

            <Button Content="Dosya Seç"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Background="#00D1FF"
                    Foreground="#1E1E26"
                    FontWeight="Bold"
                    Click="BtnFileSelect_Click"/>
        </Grid>

        <!-- INPUT ALANI -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SOL TARAF -->
            <TextBlock Text="Word" Grid.Row="0" Grid.Column="0" Foreground="White"/>
            <TextBox x:Name="eng_textbox" Grid.Row="0" Grid.Column="1" Margin="5"/>

            <TextBlock Text="Type" Grid.Row="1" Grid.Column="0" Foreground="White"/>
            <TextBox x:Name="type_textbox" Grid.Row="1" Grid.Column="1" Margin="5"/>

            <TextBlock Text="Meaning" Grid.Row="2" Grid.Column="0" Foreground="White"/>
            <TextBox x:Name="meaning_textbox" Grid.Row="2" Grid.Column="1" Margin="5"/>

            <!-- SAĞ TARAF -->
            <TextBlock Text="Root" Grid.Row="0" Grid.Column="2" Foreground="White"/>
            <TextBox x:Name="root_textbox" Grid.Row="0" Grid.Column="3" Margin="5"/>

            <TextBlock Text="Root Type" Grid.Row="1" Grid.Column="2" Foreground="White"/>
            <TextBox x:Name="root_type_textbox" Grid.Row="1" Grid.Column="3" Margin="5"/>

            <TextBlock Text="Root Meaning" Grid.Row="2" Grid.Column="2" Foreground="White"/>
            <TextBox x:Name="root_meaning_textbox" Grid.Row="2" Grid.Column="3" Margin="5"/>
        </Grid>

        <!-- BUTONLAR -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">

            <Button Content="Ekle"
                    Width="120"
                    Background="#5EFD77"
                    Click="ekle_buton_Click"/>

            <Button Content="Güncelle"
                    Width="120"
                    Background="#E4960B"
                    Click="guncelle_buton_Click"/>

            
        </StackPanel>

        <Grid Grid.Row="4">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="count_label"
               Text="00 Kelime"
               Foreground="#00D1FF"
               FontSize="16"
               HorizontalAlignment="Right"
               Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto">

                <ItemsControl x:Name="WordItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E1E1E"
                    Margin="10"
                    Padding="15"
                    CornerRadius="10"
                    BorderBrush="#333"
                    BorderThickness="1">

                                <StackPanel>

                                    <!-- Kelime -->
                                    <TextBlock Text="{Binding Key}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"/>

                                    <!-- Type -->
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap">
                                    <Run Text="Type: " FontWeight="Bold" Foreground="#4FC3F7"/>
                                    <Run Text="{Binding Value.Type}"/>
                                    </TextBlock>

                                    <!-- Meaning -->
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,4,0,0">
                                    <Run Text="Meaning: " FontWeight="Bold" Foreground="#4FC3F7"/>
                                    <Run Text="{Binding Value.Meaning}"/>
                                    </TextBlock>

                                    <Separator Margin="0,8,0,8"/>

                                    <TextBlock Text="Root:"
                                    Foreground="Gray"
                                    FontSize="12"/>

                                    <!-- Root -->
                                    <TextBlock Foreground="#CCCCCC" Margin="0,4,0,0">
                                    <Run Text="Root: " FontWeight="Bold" Foreground="#4FC3F7"/>
                                    <Run Text="{Binding Value.Root}"/>
                                    </TextBlock>

                                    <!-- Root Type -->
                                    <TextBlock Foreground="#CCCCCC" Margin="0,4,0,0">
                                    <Run Text="Root Type: " FontWeight="Bold" Foreground="#4FC3F7"/>
                                    <Run Text="{Binding Value.RootType}"/>
                                    </TextBlock>


                                    <!-- Root Meaning -->
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,4,0,0">
                                    <Run Text="Root Meaning: " FontWeight="Bold" Foreground="#4FC3F7"/>
                                    <Run Text="{Binding Value.RootMeaning}"/>
                                    </TextBlock>

                                    <!-- Butonlar -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="1"
                                        Content="Güncelle"
                                        Style="{StaticResource ModernButton}"
                                        Tag="{Binding Key}"
                                        Click="KartGuncelle_Click"/>

                                        <Button Grid.Column="3"
                                        Content="Sil"
                                        Style="{StaticResource DangerButton}"
                                        Tag="{Binding Key}"
                                        Click="KartSil_Click"/>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</Window>