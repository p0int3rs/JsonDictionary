<Window x:Class="JsonDictionary.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Word Game"
        Height="600"
        Width="900"
        Background="#121212"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Modern Answer Button -->
        <Style x:Key="AnswerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#3E3E42"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- ÜST BAR -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="ScoreText"
                       Text="Score: 0"
                       Foreground="#4FC3F7"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="QuestionCounterText"
                       Grid.Column="1"
                       Text="Question 1 / 10"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"/>

            <TextBlock x:Name="TimerText"
                       Grid.Column="2"
                       Text="00:30"
                       Foreground="#FF5252"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </Grid>

        <!-- SORU KARTI -->
        <Border Grid.Row="1"
                Background="#1E1E1E"
                CornerRadius="15"
                Padding="30"
                BorderBrush="#333"
                BorderThickness="1"
                Margin="0,0,0,30">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="What is the meaning of:"
                           Foreground="#AAAAAA"
                           FontSize="18"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="QuestionWordText"
                           Text="Example"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>

        <!-- CEVAP SEÇENEKLERİ -->
        <Grid Grid.Row="2" x:Name="AnswerGrid">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button x:Name="AnswerButton1"
                    Grid.Row="0" Grid.Column="0"
                    Content="Answer A"
                    Style="{StaticResource AnswerButton}"
                    Click="Answer_Click"/>

            <Button x:Name="AnswerButton2"
                    Grid.Row="0" Grid.Column="1"
                    Content="Answer B"
                    Style="{StaticResource AnswerButton}"
                    Click="Answer_Click"/>

            <Button x:Name="AnswerButton3"
                    Grid.Row="1" Grid.Column="0"
                    Content="Answer C"
                    Style="{StaticResource AnswerButton}"
                    Click="Answer_Click"/>

            <Button x:Name="AnswerButton4"
                    Grid.Row="1" Grid.Column="1"
                    Content="Answer D"
                    Style="{StaticResource AnswerButton}"
                    Click="Answer_Click"/>

        </Grid>

    </Grid>
</Window>